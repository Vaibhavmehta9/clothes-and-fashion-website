{
  "name": "styleverse-marketplace",
  "version": "1.0.0",
  "description": "StyleVerse – Multi-Vendor Fashion Marketplace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "seed": "npm run seed --workspace=scripts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "packageManager": "npm@10.2.3",
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
