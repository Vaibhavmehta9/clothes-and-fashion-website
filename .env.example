# ==============================================
# STYLEVERSE MARKETPLACE – ENVIRONMENT VARIABLES
# ==============================================
# Copy this to .env in apps/api and fill in values

# ---- SERVER ----
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ---- MONGODB ----
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/styleverse?retryWrites=true&w=majority

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- CLOUDINARY ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- RAZORPAY (or STRIPE) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ---- SMTP (for emails) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=StyleVerse <noreply@styleverse.com>

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ==============================================
# CUSTOMER WEB APP (apps/web)
# ==============================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_CLOUDINARY_URL=https://res.cloudinary.com/your_cloud_name
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
VITE_APP_NAME=StyleVerse

# ==============================================
# ADMIN APP (apps/admin)
# ==============================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_APP_NAME=StyleVerse Admin
